# Kick CLI Configuration
# Authentication uses Auth0 PKCE OAuth Flow
# Run 'kick auth login' to authenticate (no manual setup needed)

# Set to 1 for the default profile
ACTIVE=true

# OAuth Tokens (populated automatically after 'kick auth login')
KICK_ACCESS_TOKEN=
KICK_REFRESH_TOKEN=
KICK_TOKEN_EXPIRES_AT=

# API Base URL (optional - defaults to production)
KICK_BASE_URL=https://use.kick.co

# Auth0 Configuration (optional - defaults are built-in)
# Only override these for development/testing
# KICK_AUTH0_DOMAIN=auth.kick.co
# KICK_AUTH0_CLIENT_ID=nxwpRHdJfzjF335hJIHSDPgG0y16fRTl
# KICK_AUTH0_AUDIENCE=https://use.kick.co
