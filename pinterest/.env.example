# Pinterest API v5 credentials
# Docs:
# - OAuth setup: https://developers.pinterest.com/docs/getting-started/set-up-authentication-and-authorization/
# - API calls: https://developers.pinterest.com/docs/getting-started/make-an-api-call/
ACTIVE=true

# OAuth app credentials
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://localhost/

# API host
# Use https://api-sandbox.pinterest.com/v5 for Pinterest Sandbox.
BASE_URL=https://api.pinterest.com/v5

# OAuth tokens (managed by `pinterest auth login` / `pinterest auth refresh`)
ACCESS_TOKEN=
REFRESH_TOKEN=
TOKEN_EXPIRES_AT=
REFRESH_TOKEN_EXPIRES_AT=
