# CJ Affiliate CLI credentials.
# Mark this profile as the default the CLI loads when no --profile is given.
ACTIVE=true

# CJ Personal Access Token (REST + GraphQL APIs).
# Generate at https://members.cj.com/member/PersonalAccessTokens/tokens.cj
PERSONAL_ACCESS_TOKEN=

# CJ publisher company id ("requestor-cid"), required by every advertiser-
# lookup call. Find it in the URL after signing in to https://members.cj.com.
PUBLISHER_ID=

# Optional override for the playwright-cli persistent session name used by
# the browser-driven Marketplace apply flow. Default: cj
# BROWSER_SESSION=cj

# Optional API base URL override (defaults to advertiser-lookup.api.cj.com).
# BASE_URL=https://advertiser-lookup.api.cj.com
