# ClickBank CLI credentials and configuration
#
# This is a TEMPLATE — do NOT copy it to a `.env` in this repo root.
# Real credentials live in the user-local profile path:
#   ~/.local/share/cli-tools/clickbank/authentication_profiles/<profile>/.env
#
# Use `clickbank auth login` to create/manage profiles. To edit a
# profile's env directly, open the file under the path above.

# Set to 1 in the profile that should be selected when no --profile flag
# is given. Exactly one profile under ~/.local/share/cli-tools/clickbank/
# authentication_profiles/ should set this.
ACTIVE=true

# Required: raw ClickBank REST API key (used by orders, products, quickstats).
# Create the API key from your primary ClickBank account's API Management area.
API_KEY=

# Optional override; production default is already configured.
BASE_URL=https://api.clickbank.com/rest/1.3

# Optional: your ClickBank affiliate nickname. When set, marketplace
# commands emit fully-formed hoplinks of the form
#   https://hop.clickbank.net/?affiliate=<your-nick>&vendor=<vendor>
# When unset, hoplinks include a literal '{affiliate}' placeholder.
AFFILIATE_NICKNAME=
