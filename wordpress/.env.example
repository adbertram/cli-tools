# WordPress CLI Credentials

# Set to true for the default profile
ACTIVE=true

# WordPress site URL (e.g., https://example.com/wp-json/wp/v2)
URL=

# WordPress authentication credentials
USERNAME=
APP_PASSWORD=

# Optional WordPress.com/Jetpack OAuth credentials
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=
WPCOM_SITE=
WPCOM_REDIRECT_URI=
