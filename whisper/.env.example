# Whisper CLI (whisper.cpp wrapper) configuration
# This file documents shape only. Real values live in the user profile:
#   ~/.local/share/cli-tools/whisper/.env
ACTIVE=true

# Non-authentication configuration (whisper.cpp is a local CLI, no auth).

# Path to the ggml model file.
# Default: ~/.local/share/cli-tools/whisper/models/ggml-small.en.bin
# WHISPER_CPP_MODEL=~/.local/share/cli-tools/whisper/models/ggml-small.en.bin

# Underlying whisper.cpp command name (default: whisper-cli).
# WHISPER_CLI_COMMAND=whisper-cli

# Optional: absolute path to the whisper.cpp binary (wins over the command name).
# WHISPER_CLI_PATH=/opt/homebrew/bin/whisper-cli

# Optional: default initial prompt to bias vocabulary/spellings.
# An explicit --prompt on `transcripts create` overrides this; unset means
# no prompt is passed to whisper-cli.
# WHISPER_CPP_PROMPT=worktree, subagent, Codex
