# Fedex API Credentials
# Get these from: https://developer.fedex.com/api/en-us/catalog/pickup/v1/docs.html

# OAuth Credentials
CLIENT_ID=
CLIENT_SECRET=

# API Base URL (optional - defaults to production)
BASE_URL=https://apis.fedex.com

# OAuth Tokens (populated automatically after login)
ACCESS_TOKEN=
REFRESH_TOKEN=
TOKEN_EXPIRES_AT=

# Profile marker (exactly one profile should have this set to 1)
ACTIVE=true

# Default pickup address
DEFAULT_STREET=
DEFAULT_CITY=
DEFAULT_STATE=
DEFAULT_POSTAL=
DEFAULT_RESIDENTIAL=false
DEFAULT_CARRIER=FDXE
DEFAULT_ACCOUNT=
DEFAULT_PACKAGE_LOCATION=FRONT
