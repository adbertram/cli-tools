ACTIVE=true
BASE_URL=https://api.ebay.com

# eBay OAuth App Credentials (from https://developer.ebay.com/my/keys)
CLIENT_ID=
CLIENT_SECRET=

# Redirect URI (RuName from eBay Developer Portal)
# This must match exactly what's configured in your eBay app
REDIRECT_URI=

# Environment: "sandbox" or "production"
ENVIRONMENT=production

# OAuth Tokens (populated automatically after 'ebay auth login')
ACCESS_TOKEN=
REFRESH_TOKEN=
TOKEN_EXPIRES_AT=

# Default Ship-From Address
FROM_NAME=
FROM_STREET=
FROM_CITY=
FROM_STATE=
FROM_ZIP=
FROM_COUNTRY=US
FROM_PHONE=
