# YouTube CLI profile configuration template.
#
# Real OAuth credentials are owned by the CLI-tools secret manager and are
# collected interactively by `youtube auth login` (which then completes the
# browser consent flow and writes token.json into the profile data dir).
# Do NOT paste real CLIENT_ID / CLIENT_SECRET values here.

ACTIVE=true

# Auth type for this profile (YouTube Data API v3 desktop OAuth).
AUTH_TYPE=google_oauth_desktop

# OAuth client credentials (placeholders — set via `youtube auth login`).
# CLIENT_ID=
# CLIENT_SECRET=

# Browser-session commands run headless by default.
# HEADLESS=true
