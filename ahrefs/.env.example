ACTIVE=true

# Ahrefs Configuration
# Browser session is stored in the profile directory (no credentials needed)

# Base URL
BASE_URL=https://app.ahrefs.com

# Browser settings
# Set to false to see the browser window (useful for debugging)
HEADLESS=true

# Auth detection (CSS selector that exists when logged in)
AUTH_INDICATOR_SELECTOR=.user-menu

# Login redirect pattern (URL pattern indicating redirect to login page)
LOGIN_REDIRECT_PATTERN=/user/login

# Response cache settings
# Enable/disable data-level caching (default: true)
CACHE_ENABLED=true
# Cache time-to-live in seconds (default: 3600)
CACHE_TTL=3600
