# macspeech CLI configuration (shape only — no secrets)
#
# macspeech transcribes on-device via a bundled MacSpeech.app helper. There is
# no network service and no authentication, so there are no credentials here.

# Default contextual strings for vocabulary biasing (semicolon-separated).
# Fed to SFSpeechRecognitionRequest.contextualStrings when --contextual-strings
# is omitted. Unset by default.
# MACSPEECH_CONTEXTUAL_STRINGS=worktree;subagent;detached HEAD;Codex

# Override the directory holding MacSpeech.app (advanced/diagnostics only).
# The Speech Recognition TCC grant is path-specific, so changing this requires
# re-granting permission for the new path.
# MACSPEECH_INSTALL_DIR=
