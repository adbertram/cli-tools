# Podio CLI Configuration
# Copy this file to .env and fill in your credentials

ACTIVE=true

# OAuth Client Credentials (required for all auth methods)
# Get these from https://podio.com/settings/api
CLIENT_ID=
CLIENT_SECRET=

# Access token (obtained via 'podio auth login')
ACCESS_TOKEN=
REFRESH_TOKEN=
REDIRECT_URI=

# Optional: User Credentials (alternative auth method)
# USERNAME=your_email@example.com
# PASSWORD=your_password

# Optional: App Authentication (single app only)
# APP_ID=
# APP_TOKEN=

# Default IDs (optional, used when --space-id or --org-id not specified)
ORGANIZATION_ID=
WORKSPACE_ID=

# Retry Configuration (optional)
# RETRY_MAX_ATTEMPTS=5
# RETRY_BASE_DELAY=2.0
# RETRY_MAX_DELAY=60.0
# RETRY_EXPONENTIAL_BASE=2.0
# RETRY_JITTER=true
# RETRY_ON_RATE_LIMIT=true
