# DevTo API Credentials
# Get these from: https://developers.forem.com/api/v1
ACTIVE=true

# API Key (if using API key auth)
API_KEY=

# Personal Access Token (if using PAT auth)
PERSONAL_ACCESS_TOKEN=

# OAuth Credentials (if using OAuth)
CLIENT_ID=
CLIENT_SECRET=

# API Base URL (optional - defaults to production)
BASE_URL=https://dev.to/api

# OAuth Tokens (populated automatically after login)
ACCESS_TOKEN=
REFRESH_TOKEN=
TOKEN_EXPIRES_AT=
