    "exec": {
      "help": "Execute raw cliclick commands",
      "usage_instructions": "Execute raw cliclick native command strings directly. Use for complex multi-step sequences in a single call. Syntax: c:x,y (click), dc:x,y (double-click), m:x,y (move), t:text (type), kp:key (press), w:ms (wait), etc.",
      "arguments": [],
      "options": [],
      "commands": {
        "run": {
          "help": "Execute raw cliclick command string. Accepts cliclick native syntax for complex command sequences. Command syntax: c:x,y      - Click at coordinates dc:x,y     - Double-click rc:x,y     - Right-click tc:x,y     - Triple-click m:x,y      - Move mouse dd:x,y     - Drag start (mouse down) dm:x,y     - Drag move du:x,y     - Drag end (mouse up) kp:key     - Press key kd:keys    - Key down (modifiers) ku:keys    - Key up (modifiers) t:text     - Type text w:ms       - Wait milliseconds p          - Print position cp:x,y     - Color at position Example: cliclick exec run \"c:100,200 w:500 t:hello\" cliclick exec run \"m:500,300 c:. w:1000 t:test\" --test",
          "usage_instructions": "Execute a raw cliclick command string with native syntax. COMMANDS is a space-separated string (e.g. \"c:100,200 w:500 t:hello\"). Use --test/-T for dry run. Native commands: c:x,y (click), dc:x,y (double-click), rc:x,y (right-click), tc:x,y (triple-click), m:x,y (move), dd:x,y (drag down), dm:x,y (drag move), du:x,y (drag up), kp:key (press), kd:keys (key down), ku:keys (key up), t:text (type), w:ms (wait), p (print position), cp:x,y (color at).",
          "arguments": [
            {
              "name": "commands",
              "type": "TEXT",
              "required": true,
              "help": "Space-separated cliclick commands (e.g., 'c:100,200 w:500 t:hello')"
            }
          ],
          "options": [
            {
              "name": "--verbose",
              "type": "bool",
              "required": false,
              "help": "Verbose output from cliclick",
              "short": "-V"
            },
            {
              "name": "--test",
              "type": "bool",
              "required": false,
              "help": "Test mode (no actual execution)",
              "short": "-T"
            },
            {
              "name": "--no-restore",
              "type": "bool",
              "required": false,
              "help": "Don't restore mouse position"
            },
            {
              "name": "--table",
              "type": "bool",
              "required": false,
              "help": "Display as table",
              "short": "-t"
            }
          ]
        },
        "wait": {
          "help": "Wait for specified milliseconds. Example: cliclick exec wait 1000 cliclick exec wait 500 --verbose",
