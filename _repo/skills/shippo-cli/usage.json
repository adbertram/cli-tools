    "rates": {
      "help": "View and compare shipping rates",
      "usage_instructions": "Rate comparison -- list rates for a shipment, get rate details, estimate rates without creating a shipment.",
      "arguments": [],
      "options": [
        {
          "name": "--profile",
          "type": "TEXT",
          "required": false,
          "help": "Auth profile name"
        }
      ],
      "commands": {
        "estimate": {
          "help": "Estimate shipping rates without creating a label. Creates a temporary shipment to retrieve available rates. Uses FROM address from environment variables (FROM_NAME, FROM_STREET1, FROM_CITY, FROM_STATE, FROM_ZIP, FROM_COUNTRY). For international destinations (non-US), customs information is automatically generated. You can override the defaults with --description and --value. Weight is in OUNCES (oz). Common conversions: 4oz = 0.25 lbs, 8oz = 0.5 lbs, 16oz = 1 lb Dimensions are in INCHES. Defaults: 7\" x 4\" x 1\"",
          "examples": [
            "shippo rates estimate --weight 8 --to-country US --to-zip 90210",
            "shippo rates estimate --weight 32 --to-country US --to-zip 90210 \\",
            "shippo rates estimate --weight 4 --to-country FR",
            "shippo rates estimate --weight 8 --to-country FR --value 50",
            "shippo rates estimate --weight 4 --to-country FR --filter \"provider:usps\""
          ],
          "usage_instructions": "Use to estimate rates without creating a shipment.",
          "arguments": [],
          "options": [
            {
              "name": "--weight",
              "type": "FLOAT",
              "required": true,
              "help": "Package weight in ounces (required)",
              "short": "-w"
            },
            {
              "name": "--to-country",
              "type": "TEXT",
              "required": true,
              "help": "Destination country code, e.g., US, CA, FR (required)",
              "short": "-c"
