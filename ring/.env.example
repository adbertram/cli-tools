# Ring CLI credentials for the python-ring-doorbell consumer auth flow.
# This CLI does NOT use Ring Partner API app credentials such as CLIENT_ID,
# CLIENT_SECRET, redirect URLs, webhook URLs, or HMAC keys.
# The OAuth token (with refresh token) is persisted automatically in the
# profile data directory after first login + 2FA.

ACTIVE=true

# Ring account email
USERNAME=

# Ring account password
PASSWORD=

# Base URL (rarely needs overriding)
BASE_URL=https://api.ring.com
