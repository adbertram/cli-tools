# Google CLI configuration
# OAuth client values are stored as secret:// references in the active auth
# profile. OAuth tokens are CLI-managed runtime state in token.json.
# Do not put reusable secrets in this file.

# Set to true for the default profile
ACTIVE=true

# Search Console site URL (optional - default site for searchconsole commands)
GOOGLE_SEARCHCONSOLE_SITE=

# GA4 property ID (optional - default property for analytics commands)
GOOGLE_ANALYTICS_PROPERTY_ID=
