# LinkedIn CLI credentials
# All post commands use LinkedIn's official OAuth API only.
ACTIVE=true

# OAuth application credentials
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=

# Optional: override the scopes requested by `linkedin auth login`.
# Default scope is `w_member_social`.
# Add restricted scopes only if your LinkedIn app is approved for them:
# - r_member_social for member post list/get/search
# - w_organization_social for page post create/update/delete
# - r_organization_social for page post list/get/search
# LINKEDIN_SCOPES=w_member_social

# Optional: override the versioned Posts API header.
# Verified live on 2026-05-18: /rest/posts accepted 202604 and rejected 202605 with HTTP 426.
LINKEDIN_VERSION=202604

# Optional: default page author URN for `linkedin page posts ...`
# Example: urn:li:organization:123456 or urn:li:organizationBrand:123456
LINKEDIN_PAGE_URN=

# Optional: default personal-account author URN for `linkedin user posts ...`
# Use this when the app cannot call /v2/me because it lacks r_liteprofile.
# Example: urn:li:person:123456
LINKEDIN_PERSON_URN=

# Optional: override the API base URL
BASE_URL=https://api.linkedin.com/rest

# OAuth tokens populated automatically after `linkedin auth login`
ACCESS_TOKEN=
REFRESH_TOKEN=
TOKEN_EXPIRES_AT=
