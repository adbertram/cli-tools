# Amazon Configuration
# Browser session is stored in the profile directory (no credentials needed)
ACTIVE=true

# Base URL
BASE_URL=https://www.amazon.com

# Browser settings
# Set to false to see the browser window (useful for debugging)
HEADLESS=true

# Authentication Configuration
# Comma-separated regex patterns for auth cookies (used by is_authenticated)
AUTH_COOKIE_NAMES=session.*,auth,token,sid

# CSS selector indicating authenticated state (optional)
AUTH_SELECTOR=

# URL pattern indicating login page (auth fails if URL matches this)
AUTH_URL_PATTERN=

# Seconds to wait for auto-monitoring login (default: 60)
AUTH_TIMEOUT=60

# Seconds between auth checks during login (default: 2)
AUTH_POLL_INTERVAL=2

# Response cache settings
# Enable/disable HAR-based response caching (default: true)
CACHE_ENABLED=true
# Cache time-to-live in seconds (default: 3600)
CACHE_TTL=3600
