# Whisper CLI Wrapper Configuration
# Documentation: https://github.com/openai/whisper

# Set to 1 for the default profile
ACTIVE=true

# Underlying CLI command (defaults to whisper)
# WHISPER_CLI_COMMAND=whisper

# Optional: Full path to CLI executable (if not in PATH)
# WHISPER_CLI_PATH=

# Optional: default Whisper model when --model is not passed (defaults to turbo)
# OPENAI_WHISPER_MODEL=turbo

# Optional: default vocabulary-biasing prompt when --initial-prompt is not passed.
# Passed to the engine as --initial_prompt. Unset/empty means no prompt is sent.
# OPENAI_WHISPER_INITIAL_PROMPT=
