# PartnerStack Partner API credentials
# Get these from: https://docs.partnerstack.com/docs/partner-api
ACTIVE=true

# Partner API key for Bearer-auth commands: rewards, marketplace, partnerships.
API_KEY=

# PartnerStack Basic auth public/secret key pair for form-templates and applications.
USERNAME=
PASSWORD=

# API Base URL (optional - defaults to production)
BASE_URL=https://api.partnerstack.com/api/v2
