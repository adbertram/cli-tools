# Notion CLI configuration
# Authentication uses a Notion integration token stored in the CLI-tools
# secret manager (keychain entry 'notion-api-token'), NOT this file.
# Set or rotate it with: notion auth login
# Do not put reusable secrets in this file.

# Set to true for the default profile
ACTIVE=true

# Optional: override the Notion API version (defaults to 2025-09-03).
# Uncomment and set if you need to pin a different version.
# NOTION_API_VERSION=2025-09-03
