# Copilot CLI configuration
# Profile (.env) files hold non-secret config such as DATAVERSE_URL,
# AZURE_TENANT_ID, AZURE_CLIENT_ID, and AZURE_CLI_EXPECTED_USER. Sensitive
# fields are stored as secret://<name> references resolved from the CLI-tools
# secret manager. Do not put reusable secrets in this file.

# Set to true for the default profile
ACTIVE=true

# Dataverse environment URL (required) — e.g., https://yourorg.crm.dynamics.com
DATAVERSE_URL=

# Azure AD tenant ID (optional)
AZURE_TENANT_ID=

# Azure AD application (client) ID (optional)
AZURE_CLIENT_ID=

# Expected signed-in Azure CLI user, verified by auth commands (optional)
AZURE_CLI_EXPECTED_USER=

# Sensitive fields — store raw values in the CLI-tools secret manager and
# reference them here as secret://<name>. Never commit raw secret values.
AZURE_CLIENT_SECRET=secret://copilot-azure-client-secret
M365_SDK_CLIENT_SECRET=secret://copilot-m365-sdk-client-secret
DIRECTLINE_SECRET=secret://copilot-directline-secret
