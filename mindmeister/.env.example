# Mindmeister API Credentials
# Get these from: https://developers.mindmeister.com/docs

ACTIVE=true

# API Key (if using API key auth)
MINDMEISTER_API_KEY=

# OAuth Credentials (if using OAuth)
MINDMEISTER_CLIENT_ID=
MINDMEISTER_CLIENT_SECRET=

# API Base URL (optional - defaults to production)
MINDMEISTER_BASE_URL=https://www.mindmeister.com/services/rest/oauth2

# OAuth Tokens (populated automatically after login)
MINDMEISTER_ACCESS_TOKEN=
MINDMEISTER_REFRESH_TOKEN=
MINDMEISTER_TOKEN_EXPIRES_AT=
