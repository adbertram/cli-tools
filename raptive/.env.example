# Raptive Configuration

# Base URLs
BASE_URL=https://dashboard.raptive.com
API_BASE_URL=https://publisher-api.raptive.com

# Site ID (your Raptive site identifier)
# Find this in your dashboard URL: dashboard.raptive.com/sites/{SITE_ID}/dashboard
SITE_ID=

# Browser settings
# Set to false to see the browser window (useful for debugging)
HEADLESS=true

# Auth test configuration
LOGIN_REDIRECT_PATTERN=/login

# Response cache settings
# Enable/disable data-level caching (default: true)
CACHE_ENABLED=true
# Cache time-to-live in seconds (default: 3600)
CACHE_TTL=3600

# Profile marker (do not remove)
ACTIVE=true
