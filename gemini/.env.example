# Gemini API Credentials
# Get your API key from: https://aistudio.google.com/apikey

# Set to 1 for the default profile
ACTIVE=true

# API Key (required)
GEMINI_API_KEY=

# BigQuery billing export table for usage/cost reporting (optional)
# Format: project.dataset.table (e.g., my-project.billing.gcp_billing_export_v1_XXXXXX)
GEMINI_BIGQUERY_BILLING_TABLE=
