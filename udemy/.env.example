# Udemy Instructor API credentials
# Create an API client from your Udemy account API Clients page.
ACTIVE=true

# Bearer token for the Udemy Instructor API.
PERSONAL_ACCESS_TOKEN=

# Browser session name for browser-backed manage-page commands.
BROWSER_SESSION=udemy

# API base URL.
BASE_URL=https://www.udemy.com/instructor-api/v1
