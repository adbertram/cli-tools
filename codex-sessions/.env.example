# CodexSessions CLI Wrapper Configuration
# Documentation: https://github.com/openai/codex
ACTIVE=true

# Underlying CLI command (defaults to codex)
CLI_COMMAND=codex

# Optional: Full path to CLI executable (if not in PATH)
# CLI_PATH=

# Optional: Codex home directory. Defaults to ~/.codex
# CODEX_HOME=~/.codex

# Optional: CLI-specific override. Takes precedence over CODEX_HOME.
# CODEX_SESSIONS_CODEX_HOME=~/.codex
